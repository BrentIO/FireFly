@startuml
!include ../../../images/common-sequence.iuml

title deploy-acm\n(GitHub Action → CloudFormation)

actor "GitHub Actions Runner" as GHA

box "AWS" #ffdbbb
    participant "CloudFormation / SAM" as CF
    participant "ACM" as ACM
    participant "Route 53" as R53
end box

GHA -> CF : SAM build\ntemplate: templates/acm.yaml
GHA -> CF++ : SAM deploy\nstack: firefly-acm\nparams: CertificateDomainName, HostedZoneId
CF -> ACM++ : Request certificate\ndomain: CertificateDomainName
ACM -> R53 : Create DNS validation CNAME record
note over R53 : DNS propagation required\n(up to 30 min)
R53 --> ACM : CNAME resolves
ACM --> CF-- : Certificate issued\nCertificateArn
CF --> GHA-- : CREATE_COMPLETE / UPDATE_COMPLETE\nOutput: CertificateArn

alt Certificate DNS validation timeout
    ACM --> CF : Validation pending > 30 min
    CF --> GHA : ROLLBACK_COMPLETE
    note over GHA : Workflow fails.\nVerify Route 53 hosted zone and domain ownership.
end

alt Stack already in ROLLBACK_COMPLETE
    CF --> GHA : Stack exists in ROLLBACK_COMPLETE
    note over GHA : Workflow fails.\nManually delete the stack before re-running.
end

@enduml
