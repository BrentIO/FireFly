@startuml
!include ../../../images/common-sequence.iuml

title delete-dynamodb-firmware\n(GitHub Action → CloudFormation)

actor "GitHub Actions Runner" as GHA

box "AWS" #ffdbbb
    participant "CloudFormation / SAM" as CF
    database "DynamoDB" as DDB
end box

note over GHA : No prerequisites — runs in parallel\nwith most other delete jobs.

GHA -> CF++ : sam delete\nstack: firefly-dynamodb-firmware\n--no-prompts --region
CF -> DDB : Delete table
DDB --> CF : Table deleted
CF --> GHA-- : DELETE_COMPLETE

alt Stack does not exist
    CF --> GHA : Stack not found
    note over GHA : Workflow exits 0 (idempotent)
end

alt Deletion protection enabled on table
    DDB --> CF : AccessDeniedException
    CF --> GHA : DELETE_FAILED
    note over GHA : Workflow fails.\nDisable deletion protection manually\nbefore re-running.
end

@enduml
