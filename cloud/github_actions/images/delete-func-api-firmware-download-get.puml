@startuml
!include ../../../images/common-sequence.iuml

title delete-func-api-firmware-download-get\n(GitHub Action → CloudFormation)

actor "GitHub Actions Runner" as GHA

box "AWS" #ffdbbb
    participant "CloudFormation / SAM" as CF
    participant "API Gateway" as APIGW
end box

GHA -> CF++ : SAM delete\nstack: firefly-func-api-firmware-download-get
CF -> APIGW : Remove route\nGET /firmware/{zip_name}/download
CF --> GHA-- : DELETE_COMPLETE

@enduml
