@startuml
!include ../../images/common-sequence.iuml

title delete-func-api-firmware-status-patch\n(GitHub Action → CloudFormation)

actor "GitHub Actions Runner" as GHA

box "AWS" #ffdbbb
    participant "CloudFormation / SAM" as CF
    participant "API Gateway" as APIGW
end box

GHA -> CF++ : SAM delete\nstack: firefly-func-api-firmware-status-patch
CF -> APIGW : Remove route\nPATCH /firmware/{zip_name}/status
CF --> GHA-- : DELETE_COMPLETE

@enduml
