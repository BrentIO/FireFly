@startuml
!include ../../images/common-sequence.iuml

title delete-func-api-health-get\n(GitHub Action → CloudFormation)

actor "GitHub Actions Runner" as GHA

box "AWS" #ffdbbb
    participant "CloudFormation / SAM" as CF
    participant "API Gateway" as APIGW
end box

GHA -> CF++ : SAM delete\nstack: firefly-func-api-health-get
CF -> APIGW : Remove route\nGET /health
CF --> GHA-- : DELETE_COMPLETE

@enduml
