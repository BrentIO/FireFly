@startuml
!include ../../images/common-sequence.iuml

title deploy-func-api-firmware-get\n(GitHub Action → CloudFormation)

actor "GitHub Actions Runner" as GHA

box "AWS" #ffdbbb
    participant "CloudFormation / SAM" as CF
    participant "API Gateway" as APIGW
end box

GHA -> CF++ : describe-stacks\nfirefly-api-gateway\n→ ApiId
CF --> GHA-- : ApiId

GHA -> CF : SAM build

GHA -> CF++ : SAM deploy\nstack: firefly-func-api-firmware-get\nparams: ApiId, DynamoDbFirmwareTableName
CF -> APIGW : Register routes\nGET /firmware\nGET /firmware/{zip_name}
CF --> GHA-- : CREATE_COMPLETE / UPDATE_COMPLETE

alt api-gateway stack not found
    CF --> GHA : ValidationError
    note over GHA : Workflow fails\n(deploy-api-gateway must run first)
end

alt shared-layer ARN unresolvable
    CF --> GHA : BUILD_FAILED / ValidationError
    note over GHA : Workflow fails\n(deploy-shared-layer must run first)
end

@enduml
