@startuml
!include common-sequence.puml

title DELETE /firmware/{zip_name}

actor Client

box "Infrastructure" #ffdbbb
    participant "API Gateway" as APIGW
    participant "func-api-firmware-delete" as DeleteLambda
    participant "func-s3-firmware-deleted" as DeletedLambda
    database DynamoDB
    database S3
end box

Client -> APIGW++ : DELETE /firmware/550e8400-...zip
APIGW -> DeleteLambda++ : invoke
DeleteLambda -> DynamoDB++ : Query GSI zip_name-index\nKeyCondition: zip_name = "550e8400-...zip"

alt not found
    DynamoDB --> DeleteLambda-- : (no items)
    DeleteLambda --> APIGW-- : 404 Not Found
    APIGW --> Client-- : 404 Not Found
else already removed (DELETED or REVOKED)
    DynamoDB --> DeleteLambda-- : item\n{release_status: "DELETED" or "REVOKED", ...}
    DeleteLambda --> APIGW-- : 409 Conflict\n{"message": "Firmware is already in state '...'"}
    APIGW --> Client-- : 409 Conflict
else active firmware found
    DynamoDB --> DeleteLambda-- : item\n{release_status: "READY_TO_TEST"|"TESTING"|"ERROR", ...}
    DeleteLambda -> S3++ : DeleteObject\nKey: processed/ or errors/550e8400-...zip
    S3 --> DeleteLambda-- : success
    DeleteLambda --> APIGW-- : 202 Accepted\n{"message": "Deletion initiated"}
    APIGW --> Client-- : 202 Accepted

    S3 -\ DeletedLambda++ : S3 ObjectRemoved event (async)\n(processed/ or errors/550e8400-...zip)
    DeletedLambda -> DynamoDB++ : Query GSI zip_name-index\nKeyCondition: zip_name = "550e8400-...zip"
    DynamoDB --> DeletedLambda-- : item\n{release_status: ...}

    alt release_status == RELEASED
        DeletedLambda -> DynamoDB++ : UpdateItem\nSET release_status = "REVOKED", ttl = now + 10 days
        DynamoDB --> DeletedLambda-- : success
    else other status
        DeletedLambda -> DynamoDB++ : UpdateItem\nSET release_status = "DELETED", ttl = now + 10 days
        DynamoDB --> DeletedLambda-- : success
    end
    deactivate DeletedLambda
end

@enduml
