@startuml
!include common-sequence.iuml

title GET /firmware (list)

actor Client

box "AWS" #ffdbbb
    participant "API Gateway" as APIGW
    participant "func-api-firmware-get" as Lambda
    database DynamoDB
end box

Client -> APIGW++ : GET /firmware[?product_id=...][&version=...]
APIGW -> Lambda++ : invoke

alt no query filters
    Lambda -> DynamoDB++ : Scan (all items)
    DynamoDB --> Lambda-- : items[]
else filtered by product_id
    Lambda -> DynamoDB++ : Query GSI product_id-index\nKeyCondition: product_id = "FFC3232-2603"
    DynamoDB --> Lambda-- : items[]
else filtered by product_id and version
    Lambda -> DynamoDB++ : Query GSI product_id-index\nKeyCondition: product_id = "FFC3232-2603"\nFilterExpression: version = "2026.03.01"
    DynamoDB --> Lambda-- : items[] (may contain multiple builds)
end

note right of Lambda
    files[] and pk are excluded from list responses.
    Use GET /firmware/{zip_name} for the full record.
end note

Lambda --> APIGW-- : 200 OK\n{"items": [...]}
APIGW --> Client-- : 200 OK\n{"items": [...]}

@enduml
