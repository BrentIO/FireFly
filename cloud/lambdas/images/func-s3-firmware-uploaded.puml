@startuml
!include ../../../images/common-sequence.iuml

title func-s3-firmware-uploaded\n(S3 ObjectCreated event — GitHub Action → S3)

actor "GitHub Action" as GHA

box "AWS" #ffdbbb
    database S3
    participant "func-s3-firmware-uploaded" as Lambda
    database DynamoDB
end box

GHA -> S3++ : PutObject\nKey: incoming/{filename}.zip
S3 --> GHA-- : success
S3 -\ Lambda++ : S3 ObjectCreated event (async)\n(incoming/{filename}.zip)

Lambda -> S3++ : CopyObject incoming/ → processing/\nDeleteObject incoming/
S3 --> Lambda-- : success
Lambda -> S3++ : HeadObject (get file size)
S3 --> Lambda-- : file metadata
Lambda -> S3++ : Download ZIP to /tmp
S3 --> Lambda-- : ZIP data
Lambda -> Lambda : Compute SHA256 of ZIP\nExtract ZIP, read manifest.json\nValidate manifest schema (required fields, files array)\nVerify each file exists and matches SHA256 in manifest

alt validation succeeds
    Lambda -> DynamoDB++ : PutItem\n{release_status: "READY_TO_TEST", ...}
    DynamoDB --> Lambda-- : success
    Lambda -> S3++ : CopyObject processing/ → processed/\nDeleteObject processing/
    S3 --> Lambda-- : success
else validation fails (manifest error or checksum mismatch)
    Lambda -> DynamoDB++ : PutItem\n{release_status: "ERROR",\n error: "<reason>", ...}
    DynamoDB --> Lambda-- : success
    Lambda -> S3++ : CopyObject processing/ → errors/\nDeleteObject processing/
    S3 --> Lambda-- : success
end

deactivate Lambda

note over S3
    S3 lifecycle rules expire prefixes automatically:
    incoming/   — 1 day
    processing/ — 1 day
    errors/     — 7 days
    processed/  — 30 days
end note

@enduml
