@startuml
!include common-sequence.iuml

title func-s3-firmware-deleted\n(S3 ObjectRemoved event)

box "AWS" #ffdbbb
    database "S3\nfirefly-firmware" as S3
    participant "func-s3-firmware-deleted" as Lambda
    database "DynamoDB\nfirefly-firmware" as DDB
end box

S3 -\ Lambda++ : S3 ObjectRemoved event (async)\n(processed/{uuid}.zip or errors/{uuid}.zip)

Lambda -> Lambda : extract {uuid}.zip from key

alt non-zip or wrong prefix
    Lambda -> Lambda : ignore event
else valid zip in processed/ or errors/
    Lambda -> DDB++ : Query zip_name-index ({uuid}.zip)
    alt not found
        DDB --> Lambda-- : (no items)
        Lambda -> Lambda : raise exception
    else found
        DDB --> Lambda-- : item (pk, version, release_status)
        alt release_status in {RELEASED, REVOKED}
            Lambda -> Lambda : skip — lifecycle managed\nby func-api-firmware-status-patch
        else
            Lambda -> DDB++ : update_item\nSET release_status = DELETED, ttl = now + 10 days
            DDB --> Lambda-- : success
        end
    end
end

deactivate Lambda

@enduml
