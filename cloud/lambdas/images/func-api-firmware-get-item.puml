@startuml
!include common-sequence.iuml

title GET /firmware/{zip_name}

actor Client

box "AWS" #ffdbbb
    participant "API Gateway" as APIGW
    participant "func-api-firmware-get" as Lambda
    database DynamoDB
end box

Client -> APIGW++ : GET /firmware/{zip_name}
APIGW -> Lambda++ : invoke
Lambda -> DynamoDB++ : Query GSI zip_name-index\nKeyCondition: zip_name = "{zip_name}"

alt found
    DynamoDB --> Lambda-- : item (full record including files[])
    Lambda --> APIGW-- : 200 OK\n{full firmware record}
    APIGW --> Client-- : 200 OK\n{full firmware record}
else not found
    DynamoDB --> Lambda-- : (no items)
    Lambda --> APIGW-- : 404 Not Found\n{"message": "Firmware not found: {zip_name}"}
    APIGW --> Client-- : 404 Not Found
end

@enduml
