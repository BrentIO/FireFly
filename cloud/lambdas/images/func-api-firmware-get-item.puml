@startuml
!include common-sequence.puml

title GET /firmware/{zip_name}

actor Client

box "Infrastructure" #ffdbbb
    participant "API Gateway" as APIGW
    participant "func-api-firmware-get" as Lambda
    database DynamoDB
end box

Client -> APIGW++ : GET /firmware/550e8400-...zip
APIGW -> Lambda++ : invoke
Lambda -> DynamoDB++ : Query GSI zip_name-index\nKeyCondition: zip_name = "550e8400-...zip"

alt found
    DynamoDB --> Lambda-- : item (full record including files[])
    Lambda --> APIGW-- : 200 OK\n{full firmware record}
    APIGW --> Client-- : 200 OK\n{full firmware record}
else not found
    DynamoDB --> Lambda-- : (no items)
    Lambda --> APIGW-- : 404 Not Found\n{"message": "Firmware not found: 00000000-...zip"}
    APIGW --> Client-- : 404 Not Found
end

@enduml
