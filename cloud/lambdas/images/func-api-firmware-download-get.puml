@startuml
!include ../../images/common-sequence.iuml

title GET /firmware/{zip_name}/download

actor Client

box "AWS" #ffdbbb
    participant "API Gateway" as APIGW
    participant "func-api-firmware-download-get" as Lambda
    database DynamoDB
    collections "S3\n(private)" as S3
end box

Client -> APIGW++ : GET /firmware/{zip_name}/download
APIGW -> Lambda++ : invoke
Lambda -> DynamoDB++ : Query GSI zip_name-index\nKeyCondition: zip_name = "{zip_name}"

alt not found
    DynamoDB --> Lambda-- : (no items)
    Lambda --> APIGW-- : 404 Not Found
    APIGW --> Client-- : 404 Not Found
else DELETED
    DynamoDB --> Lambda-- : item\n{release_status: "DELETED"}
    Lambda --> APIGW-- : 410 Gone\n{"message": "Firmware has been deleted"}
    APIGW --> Client-- : 410 Gone
else PROCESSING
    DynamoDB --> Lambda-- : item\n{release_status: "PROCESSING"}
    Lambda --> APIGW-- : 409 Conflict\n{"message": "Firmware is still being processed"}
    APIGW --> Client-- : 409 Conflict
else active firmware
    DynamoDB --> Lambda-- : item\n{release_status: "READY_TO_TEST"|..., ...}
    Lambda -> S3++ : generate_presigned_url\nKey: processed/{zip_name}\nExpires: 900s
    S3 --> Lambda-- : pre-signed URL
    Lambda --> APIGW-- : 200 OK\n{"url": "https://...", "expires_in": 900}
    APIGW --> Client-- : 200 OK
    Client -> S3++ : GET (pre-signed URL)
    S3 --> Client-- : firmware ZIP
end

@enduml
